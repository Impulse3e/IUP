# Скопируйте в .env и заполните

# === Telegram (опционально, legacy) ===
TELEGRAM_BOT_TOKEN=
TELEGRAM_CHAT_ID=

# === Сервер ===
SECRET_KEY=change-me-in-production
DATABASE_URL=sqlite:///./data/iup.db
IUP_SERVER_URL=http://localhost:8000
IUP_SESSION_TOKEN=

# === Storage ===
STORAGE_BACKEND=local
STORAGE_PATH=./data/storage
S3_ENDPOINT=
S3_BUCKET=iup-evidence
S3_ACCESS_KEY=
S3_SECRET_KEY=

# === Seed admin ===
SEED_ADMIN_EMAIL=admin@example.com
SEED_ADMIN_PASSWORD=admin123

# === Agent ===
IUP_HEARTBEAT_INTERVAL=5
IUP_CHUNK_INTERVAL=30
IUP_EVIDENCE_SECONDS=10
IUP_IDENTITY_THRESHOLD=0.15

# === Proctor thresholds ===
PROCTOR_YAW_THRESHOLD=25
PROCTOR_PITCH_THRESHOLD=45
PROCTOR_ROLL_THRESHOLD=15
PROCTOR_CONFIRM_FRAMES=15
PROCTOR_ALERT_COOLDOWN=30
PROCTOR_REMINDER_INTERVAL=60
PROCTOR_AUDIO_QUIET_RMS=50
PROCTOR_AUDIO_LOUD_RMS=300
PROCTOR_AUDIO_SUSTAIN_SEC=2
PROCTOR_AUDIO_CHECK_INTERVAL=0.5

# === LTI stub ===
LTI_CLIENT_ID=
LTI_DEPLOYMENT_ID=
